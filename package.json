{
  "name": "media-thing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot server/index.ts",
    "start": "NODE_ENV=production bun server/index.ts",
    "build:mac-x64": "bun build --compile --target bun-darwin-x64 --minify --bytecode ./server/index.ts --outfile dist/video-thing-mac-x64",
    "build:linux": "bun build --compile --target bun-linux-x64 --minify --bytecode ./server/index.ts --outfile dist/video-thing-linux"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "6.0.3"
  },
  "workspaces": ["client", "server"]
}
